{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gongchenisbusy/Experimental-Assistant/schemas/literature-data-schema-v2.schema.json",
  "title": "Experimental Assistant literature-data schema v2",
  "description": "Portable contract for user-defined, evidence-grounded literature data collection.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "schema_id",
    "source",
    "material_scope",
    "primary_field_id",
    "fields"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "schema_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,95}$"
    },
    "source": {
      "type": "object",
      "required": ["kind", "version"],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      },
      "additionalProperties": true
    },
    "material_scope": {"type": "string", "minLength": 1},
    "primary_field_id": {"$ref": "#/$defs/fieldId"},
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/field"}
    }
  },
  "$defs": {
    "fieldId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "name": {
      "type": "object",
      "required": ["en"],
      "properties": {
        "en": {"type": "string", "minLength": 1},
        "zh": {"type": "string"}
      },
      "additionalProperties": false
    },
    "unit": {
      "type": "object",
      "required": ["dimension", "allowed", "canonical", "unknown_allowed", "conversions"],
      "properties": {
        "dimension": {"type": "string", "minLength": 1},
        "allowed": {"type": "array", "items": {"type": "string"}},
        "canonical": {"type": "string", "minLength": 1},
        "unknown_allowed": {"type": "boolean"},
        "conversions": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["factor", "formula"],
            "properties": {
              "canonical": {"type": "string"},
              "factor": {"type": "number"},
              "formula": {"type": "string", "minLength": 1}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "field": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "field_id",
        "name",
        "aliases",
        "type",
        "required_conditions",
        "optional_conditions",
        "missing_value_policy",
        "comparability",
        "dedup_policy",
        "conflict_policy",
        "evidence",
        "output",
        "plot"
      ],
      "properties": {
        "field_id": {"$ref": "#/$defs/fieldId"},
        "name": {"$ref": "#/$defs/name"},
        "aliases": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "type": {
          "enum": [
            "number",
            "range",
            "uncertain_number",
            "text",
            "enum",
            "boolean",
            "date",
            "datetime",
            "list",
            "nested"
          ]
        },
        "required_conditions": {"type": "array", "items": {"type": "string"}},
        "optional_conditions": {"type": "array", "items": {"type": "string"}},
        "missing_value_policy": {"enum": ["not_reported", "null", "omit", "defer"]},
        "comparability": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {"type": "boolean"},
            "require_same_unit": {"type": "boolean"},
            "rules": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": false
        },
        "dedup_policy": {"enum": ["source_field_value", "source_field", "none"]},
        "conflict_policy": {"enum": ["preserve", "prefer_reviewed", "reject_conflict"]},
        "search_hints": {"type": "array", "items": {"type": "string"}},
        "evidence": {
          "type": "object",
          "required": ["minimum_anchors"],
          "properties": {
            "minimum_anchors": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string"}
            }
          },
          "additionalProperties": true
        },
        "output": {
          "type": "object",
          "required": ["include"],
          "properties": {
            "include": {"type": "boolean"},
            "group_by": {"type": "array", "items": {"type": "string"}},
            "sort_by": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": false
        },
        "plot": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {"type": "boolean"},
            "kind": {"type": "string"}
          },
          "additionalProperties": false
        },
        "unit": {"$ref": "#/$defs/unit"},
        "choices": {"type": "array", "minItems": 1},
        "children": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/field"}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"type": {"enum": ["number", "range", "uncertain_number"]}}},
          "then": {"required": ["unit"]}
        },
        {
          "if": {"properties": {"type": {"const": "enum"}}},
          "then": {"required": ["choices"]}
        },
        {
          "if": {"properties": {"type": {"const": "nested"}}},
          "then": {"required": ["children"]}
        }
      ]
    }
  }
}
